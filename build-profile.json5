    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "targetSdkVersion": "6.1.0(23)",
        "compatibleSdkVersion": "5.0.1(13)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "nativeCompiler": "BiSheng",
          // 关键配置：强制使用 Release 构建模式
          "externalNativeOptions": {
            "path": "./src/main/cpp/CMakeLists.txt",
            // 传递 CMake 参数，强制设置构建类型为 Release
            "arguments": [
              "-DCMAKE_BUILD_TYPE=Release"
            ],
            // 添加 C/C++ 编译优化标志（会被追加到 CMake 的选项后）
            "cppFlags": "-march=armv8.2-a+crypto+fp16+rcpc -O3 -ftree-vectorize -fomit-frame-pointer -fstrict-aliasing -fno-semantic-interposition -pipe",
            // 如果希望启用 LTO，可以添加：
            // "cppFlags": "-flto=thin",
            // 仅编译 arm64-v8a 架构（根据你的设备）
            "abiFilters": [
              "arm64-v8a"
            ]
          },
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
